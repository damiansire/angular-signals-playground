{
  "name": "angular-signals-playground",
  "version": "0.0.0",
  "description": "An interactive playground and introduction to learning Angular Signals (computed, effect, linkedSignal, resource) hands-on.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "angular",
    "signals",
    "examples"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "echarts": "^6.1.0",
    "ngx-echarts": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@eslint/js": "^10.0.1",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "22.0.0",
    "autoprefixer": "^10.4.19",
    "axe-core": "^4.12.1",
    "eslint": "^10.3.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~6.3.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.4.39",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.60.1"
  }
}
